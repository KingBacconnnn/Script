-- MAIN TAB (AUTO FARM)
MainTab:CreateSection("Auto Farming")

MainTab:CreateToggle({
    Title = "Auto Farm Brainrots",
    Default = false,
    Callback = function(state)
        _G.AutoFarmBrainrots = state
        
        if state and FlightManager then
            local char = player.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local humanoid = char and char:FindFirstChildOfClass("Humanoid")
            
            _G.SavedPosition = root and root.CFrame or nil
            if humanoid then 
                humanoid.WalkSpeed = 0 
                humanoid.JumpPower = 0 
                humanoid.UseJumpPower = true
            end

            task.spawn(function()
                local function applyFreeze()
                    local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if not r then return end
                    local existing = r:FindFirstChild("AutoFarmFreeze")
                    if existing then existing:Destroy() end
                    r.AssemblyLinearVelocity = Vector3.zero
                    r.AssemblyAngularVelocity = Vector3.zero
                    local ap = Instance.new("AlignPosition")
                    ap.Name = "AutoFarmFreeze"
                    ap.Mode = Enum.PositionAlignmentMode.OneAttachment
                    ap.Attachment0 = r:FindFirstChildOfClass("Attachment") or Instance.new("Attachment", r)
                    ap.Position = r.Position
                    ap.MaxForce = 1e5  
                    ap.Responsiveness = 100  
                    ap.Parent = r
                end
                
                local function removeFreeze()
                    local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if r then
                        local fc = r:FindFirstChild("AutoFarmFreeze")
                        if fc then fc:Destroy() end
                    end
                end

                local function findBestLaunchZone()
                    local plotsFolder = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Plots")
                    if not plotsFolder then return nil end
                    
                    local bestFloors, bestPlotIndex = -1, nil
                    for _, p in ipairs(Players:GetPlayers()) do
                        local floors = p:GetAttribute("BuildFloors")
                        local plotIndex = p:GetAttribute("PlotIndex")
                        if floors and plotIndex and floors > bestFloors then
                            bestFloors = floors
                            bestPlotIndex = plotIndex
                        end
                    end
                    if not bestPlotIndex then return nil end
                    for _, plotModel in ipairs(plotsFolder:GetChildren()) do
                        local baseTemplate = plotModel:FindFirstChild("BaseTemplate")
                        local build = baseTemplate and baseTemplate:FindFirstChild("Build")
                        local launchZone = build and build:FindFirstChild("LaunchZone")
                        if launchZone and launchZone:IsA("BasePart") then
                            local modelPlotIndex = plotModel:GetAttribute("PlotIndex") or tonumber(plotModel.Name:match("Plot_(%d+)"))
                            if modelPlotIndex == bestPlotIndex then return launchZone end
                        end
                    end
                    return nil
                end

                local capturedResult = nil
                local origProcessActive = FlightManager.ProcessActive
                FlightManager.ProcessActive = function(self, flightData, result)
                    if flightData.player == player then capturedResult = result end
                    return origProcessActive(self, flightData, result)
                end

                local function holdPrompt(prompt)
                    if not prompt then return end
                    task.spawn(function()
                        pcall(function()
                            prompt:InputHoldBegin()
                            task.wait(prompt.HoldDuration + 0.1)
                            prompt:InputHoldEnd()
                        end)
                    end)
                end

                task.wait(1)
                local initialZone = ClientCore.CurrentLaunchZone or findBestLaunchZone()
                if initialZone and root then
                    removeFreeze()
                    root.AssemblyLinearVelocity = Vector3.zero
                    root.CFrame = initialZone.CFrame * CFrame.new(0, 5, 0)
                    task.wait(0.3)
                    applyFreeze()
                    ClientCore.CurrentLaunchZone = initialZone
                else applyFreeze() end

                while _G.AutoFarmBrainrots do
                    pcall(function()
                        capturedResult = nil
                        local char = player.Character
                        local rt = char and char:FindFirstChild("HumanoidRootPart")
                        local hum = char and char:FindFirstChildOfClass("Humanoid")
                        if hum and hum.WalkSpeed ~= 0 then hum.WalkSpeed = 0; hum.JumpPower = 0 end
                        if not rt then task.wait(1) return end
                        if ClientCore.IsInFlight or ClientCore.IsInLaunch or ClientCore.IsInCapture then task.wait(0.3) return end

                        local zone = ClientCore.CurrentLaunchZone or findBestLaunchZone()
                        if not zone then task.wait(2) return end

                        if (rt.Position - zone.Position).Magnitude > 5 then
                            removeFreeze()
                            rt.AssemblyLinearVelocity = Vector3.zero
                            rt.AssemblyAngularVelocity = Vector3.zero
                            rt.CFrame = zone.CFrame * CFrame.new(0, 5, 0)
                            task.wait(0.3)
                            applyFreeze()
                        end
                        ClientCore.CurrentLaunchZone = zone

                        removeFreeze()
                        FlightManager:ProcessInput()
                        task.wait(0.45)
                        EventDriven.EVENTS.CONTROLLERS.GameplayController.ProcessClick:Fire()

                        local waited = 0
                        while not ClientCore.IsInFlight and waited < 3 do
                            task.wait(0.1); waited += 0.1
                        end
                        
                        if not ClientCore.IsInFlight then
                            FlightManager:CancelLaunch()
                            applyFreeze()
                            return
                        end

                        local flightTime = capturedResult and capturedResult.timeInAir or 5
                        task.wait(flightTime + 0.5)

                        local prompt = nil
                        local captureFolder = workspace:FindFirstChild("Live") and workspace.Live:FindFirstChild("Debris") and workspace.Live.Debris:FindFirstChild("CapturBrainrots")
                        if captureFolder then
                            for _, model in ipairs(captureFolder:GetChildren()) do
                                if model:IsA("Model") then
                                    local p = model:FindFirstChildOfClass("ProximityPrompt")
                                    if p then prompt = p; break end
                                end
                            end
                        end

                        if prompt then holdPrompt(prompt); task.wait(0.3)
                        elseif capturedResult and capturedResult.spawnedBrainrots and #capturedResult.spawnedBrainrots > 0 then
                            pcall(function() Network.ClaimFlight:InvokeServer(capturedResult.spawnedBrainrots[1].uid) end)
                            ClientCore.IsInCapture = false
                            FlightManager:UpdateInFlight()
                        end

                        ClientCore.IsInFlight = false; ClientCore.IsInLaunch = false
                        if rt and zone then
                            removeFreeze()
                            rt.AssemblyLinearVelocity = Vector3.zero
                            rt.AssemblyAngularVelocity = Vector3.zero
                            rt.CFrame = zone.CFrame * CFrame.new(0, 5, 0)
                            task.wait(0.15)
                            applyFreeze()
                        end
                    end)
                    task.wait(0.1)
                end
                removeFreeze()
            end)
        else
            local char = player.Character
            local rt = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if rt then
                local fc = rt:FindFirstChild("AutoFarmFreeze")
                if fc then fc:Destroy() end
                rt.AssemblyLinearVelocity = Vector3.zero
                rt.AssemblyAngularVelocity = Vector3.zero
