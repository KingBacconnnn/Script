local function Tween(obj, props, time)
    local t = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props)
    t:Play() return t
end

local function MakeDraggable(topbar, main)
    local dragging, dragInput, dragStart, startPos
    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = main.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function NovaUI:CreateWindow(config)
    local Window = { Tabs = {}, CurrentTab = nil }

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "NovaUI_" .. tostring(math.random(1000,9999))
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = TargetParent

    -- Mobile Toggle Icon
    local ToggleBtn = Instance.new("ImageButton")
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45)
    ToggleBtn.Position = UDim2.new(0, 15, 0, 15)
    ToggleBtn.BackgroundColor3 = NovaUI.Theme.Sidebar
    ToggleBtn.Image = "rbxassetid://10734938289" -- Plane Icon
    ToggleBtn.Parent = ScreenGui
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", ToggleBtn).Color = NovaUI.Theme.Accent
    MakeDraggable(ToggleBtn, ToggleBtn)

    -- Changed from CanvasGroup to standard Frame for strict visibility control
    local MainFrame = Instance.new("Frame")
    MainFrame.Size = IsMobile and UDim2.new(0, 450, 0, 280) or UDim2.new(0, 600, 0, 400)
    MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
    MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    MainFrame.BackgroundColor3 = NovaUI.Theme.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)
    
    local PanelScale = Instance.new("UIScale")
    PanelScale.Scale = 1
    PanelScale.Parent = MainFrame
    
    -- Absolute Visibility Toggle Logic
    local isUIOpen = true
    ToggleBtn.Activated:Connect(function()
        isUIOpen = not isUIOpen
        if isUIOpen then
            MainFrame.Visible = true
            Tween(PanelScale, {Scale = 1}, 0.3)
        else
            local hideTween = Tween(PanelScale, {Scale = 0.01}, 0.25)
            hideTween.Completed:Connect(function()
                if not isUIOpen then
                    MainFrame.Visible = false
                end
            end)
        end
    end)

    -- Sidebar
    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 140, 1, 0)
    Sidebar.BackgroundColor3 = NovaUI.Theme.Sidebar
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame

    local TopBar = Instance.new("Frame")
    TopBar.Size = UDim2.new(1, 0, 0, 40)
    TopBar.BackgroundTransparency = 1
    TopBar.Parent = MainFrame
    MakeDraggable(TopBar, MainFrame)

    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, -20, 0, 40)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = config.Title or "Nova UI"
    Title.TextColor3 = NovaUI.Theme.Text
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Parent = Sidebar

    local TabContainer = Instance.new("ScrollingFrame")
    TabContainer.Size = UDim2.new(1, -10, 1, -50)
    TabContainer.Position = UDim2.new(0, 5, 0, 40)
    TabContainer.BackgroundTransparency = 1
    TabContainer.ScrollBarThickness = 0
    TabContainer.Parent = Sidebar
    local TabList = Instance.new("UIListLayout")
    TabList.Padding = UDim.new(0, 5)
    TabList.Parent = TabContainer

    local ContentContainer = Instance.new("Frame")
    ContentContainer.Size = UDim2.new(1, -140, 1, 0)
    ContentContainer.Position = UDim2.new(0, 140, 0, 0)
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Parent = MainFrame

    function Window:CreateTab(name)
        local Tab = {}
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 30)
        TabBtn.BackgroundColor3 = NovaUI.Theme.Sidebar
        TabBtn.Text = "  " .. name
        TabBtn.TextColor3 = NovaUI.Theme.SubText
        TabBtn.Font = Enum.Font.GothamMedium
        TabBtn.TextSize = 13
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.AutoButtonColor = false
        TabBtn.Parent = TabContainer
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Size = UDim2.new(1, -20, 1, -20)
        TabContent.Position = UDim2.new(0, 10, 0, 10)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 2
        TabContent.Visible = false
        TabContent.Parent = ContentContainer
        local ContentList = Instance.new("UIListLayout")
        ContentList.Padding = UDim.new(0, 8)
        ContentList.Parent = TabContent

        TabContent.ChildAdded:Connect(function()
            RunService.RenderStepped:Wait()
            TabContent.CanvasSize = UDim2.new(0, 0, 0, ContentList.AbsoluteContentSize.Y + 20)
        end)

        TabBtn.Activated:Connect(function()
            for _, t in pairs(Window.Tabs) do
                t.Content.Visible = false
                Tween(t.Btn, {BackgroundColor3 = NovaUI.Theme.Sidebar, TextColor3 = NovaUI.Theme.SubText}, 0.2)
            end
            TabContent.Visible = true
            Tween(TabBtn, {BackgroundColor3 = NovaUI.Theme.Section, TextColor3 = NovaUI.Theme.Accent}, 0.2)
        end)

        if not Window.CurrentTab then
            Window.CurrentTab = TabContent
            TabContent.Visible = true
            TabBtn.BackgroundColor3 = NovaUI.Theme.Section
            TabBtn.TextColor3 = NovaUI.Theme.Accent
        end

        table.insert(Window.Tabs, {Btn = TabBtn, Content = TabContent})

        function Tab:CreateSection(titleText)
            local Sec = Instance.new("TextLabel")
            Sec.Size = UDim2.new(1, 0, 0, 20)
            Sec.BackgroundTransparency = 1
            Sec.Text = titleText
            Sec.TextColor3 = NovaUI.Theme.Accent
            Sec.Font = Enum.Font.GothamBold
            Sec.TextSize = 12
            Sec.TextXAlignment = Enum.TextXAlignment.Left
            Sec.Parent = TabContent
        end

        function Tab:CreateToggle(config)
            local state = config.Default or false
            local ToggleFrame = Instance.new("TextButton")
            ToggleFrame.Size = UDim2.new(1, 0, 0, 40)
            ToggleFrame.BackgroundColor3 = NovaUI.Theme.Section
            ToggleFrame.Text = ""
            ToggleFrame.AutoButtonColor = false
            ToggleFrame.Parent = TabContent
            Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 6)

            local Lbl = Instance.new("TextLabel")
            Lbl.Size = UDim2.new(1, -60, 1, 0)
            Lbl.Position = UDim2.new(0, 10, 0, 0)
            Lbl.BackgroundTransparency = 1
            Lbl.Text = config.Title
            Lbl.TextColor3 = NovaUI.Theme.Text
            Lbl.Font = Enum.Font.Gotham
            Lbl.TextSize = 13
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.Parent = ToggleFrame

            local Switch = Instance.new("Frame")
            Switch.Size = UDim2.new(0, 36, 0, 18)
            Switch.Position = UDim2.new(1, -46, 0.5, -9)
            Switch.BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.ToggleOff
            Switch.Parent = ToggleFrame
            Instance.new("UICorner", Switch).CornerRadius = UDim.new(1, 0)

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = UDim2.new(0, state and 20 or 2, 0.5, -7)
            Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Circle.Parent = Switch
            Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

            local function Fire()
                Tween(Switch, {BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.ToggleOff})
                Tween(Circle, {Position = UDim2.new(0, state and 20 or 2, 0.5, -7)})
                if config.Callback then task.spawn(config.Callback, state) end
            end

            ToggleFrame.Activated:Connect(function()
                state = not state
                Fire()
            end)
            if state then Fire() end
        end

        function Tab:CreateSlider(config)
            local val = config.Default or config.Min
            local SliderFrame = Instance.new("Frame")
            SliderFrame.Size = UDim2.new(1, 0, 0, 50)
            SliderFrame.BackgroundColor3 = NovaUI.Theme.Section
            SliderFrame.Parent = TabContent
            Instance.new("UICorner", SliderFrame).CornerRadius = UDim.new(0, 6)

            local Lbl = Instance.new("TextLabel")
            Lbl.Size = UDim2.new(1, -20, 0, 25)
            Lbl.Position = UDim2.new(0, 10, 0, 0)
            Lbl.BackgroundTransparency = 1
            Lbl.Text = config.Title
            Lbl.TextColor3 = NovaUI.Theme.Text
            Lbl.Font = Enum.Font.Gotham
            Lbl.TextSize = 13
            Lbl.TextXAlignment = Enum.TextXAlignment.Left
            Lbl.Parent = SliderFrame

            local ValLbl = Instance.new("TextLabel")
            ValLbl.Size = UDim2.new(0, 50, 0, 25)
            ValLbl.Position = UDim2.new(1, -60, 0, 0)
            ValLbl.BackgroundTransparency = 1
            ValLbl.Text = tostring(val)
            ValLbl.TextColor3 = NovaUI.Theme.SubText
            ValLbl.Font = Enum.Font.Gotham
            ValLbl.TextSize = 13
            ValLbl.TextXAlignment = Enum.TextXAlignment.Right
            ValLbl.Parent = SliderFrame

            local TrackBtn = Instance.new("TextButton")
            TrackBtn.Size = UDim2.new(1, -20, 0, 6)
            TrackBtn.Position = UDim2.new(0, 10, 0, 32)
            TrackBtn.BackgroundColor3 = NovaUI.Theme.ToggleOff
            TrackBtn.Text = ""
            TrackBtn.AutoButtonColor = false
            TrackBtn.Parent = SliderFrame
            Instance.new("UICorner", TrackBtn).CornerRadius = UDim.new(1, 0)

            local Fill = Instance.new("Frame")
            Fill.Size = UDim2.new((val - config.Min) / (config.Max - config.Min), 0, 1, 0)
            Fill.BackgroundColor3 = NovaUI.Theme.Accent
            Fill.Parent = TrackBtn
            Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

            local dragging = false
            local function update(input)
                local pos = math.clamp((input.Position.X - TrackBtn.AbsolutePosition.X) / TrackBtn.AbsoluteSize.X, 0, 1)
                val = math.floor(config.Min + (pos * (config.Max - config.Min)))
                Tween(Fill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1)
                ValLbl.Text = tostring(val)
                if config.Callback then config.Callback(val) end
            end

            TrackBtn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true; update(input)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    update(input)
                end
            end)
        end

        function Tab:CreateButton(config)
            local Btn = Instance.new("TextButton")
            Btn.Size = UDim2.new(1, 0, 0, 35)
            Btn.BackgroundColor3 = NovaUI.Theme.Section
            Btn.Text = config.Title
            Btn.TextColor3 = NovaUI.Theme.Text
            Btn.Font = Enum.Font.GothamMedium
            Btn.TextSize = 13
            Btn.AutoButtonColor = false
            Btn.Parent = TabContent
            Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
            Instance.new("UIStroke", Btn).Color = NovaUI.Theme.ToggleOff

            Btn.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Tween(Btn, {BackgroundColor3 = NovaUI.Theme.ToggleOff}, 0.1)
                end
            end)
            Btn.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Tween(Btn, {BackgroundColor3 = NovaUI.Theme.Section}, 0.1)
                end
            end)
            Btn.Activated:Connect(function()
                if config.Callback then config.Callback() end
            end)
        end

        function Tab:CreateParagraph(config)
            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, 60)
            Frame.BackgroundColor3 = NovaUI.Theme.Section
            Frame.Parent = TabContent
            Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 6)
            
            local Txt = Instance.new("TextLabel")
            Txt.Size = UDim2.new(1, -20, 1, -10)
            Txt.Position = UDim2.new(0, 10, 0, 5)
            Txt.BackgroundTransparency = 1
            Txt.Text = "**" .. config.Title .. "**\n" .. config.Desc
            Txt.RichText = true
            Txt.TextColor3 = NovaUI.Theme.SubText
            Txt.Font = Enum.Font.Gotham
            Txt.TextSize = 12
            Txt.TextXAlignment = Enum.TextXAlignment.Left
            Txt.TextYAlignment = Enum.TextYAlignment.Top
            Txt.Parent = Frame
        end

        return Tab
    end

    return Window
end

