-- OPEN / CLOSE ANIMATIONS
------------------------------------------------------------------------
local function openGui()
	MainFrame.Visible = true
	MainFrame.Size = UDim2.new(0, W, 0, 8)
	OpenBtn.Visible = false
	task.defer(function()
		TweenService:Create(MainFrame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, W, 0, H),
		}):Play()
	end)
end

local function closeGui()
	local t = TweenService:Create(MainFrame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = UDim2.new(0, W, 0, 8),
	})
	t:Play()
	t.Completed:Connect(function()
		MainFrame.Visible = false
		OpenBtn.Visible = true
	end)
end

OpenBtn.Activated:Connect(openGui)
CloseBtn.Activated:Connect(closeGui)

------------------------------------------------------------------------
-- DRAGGING (mouse + touch)
------------------------------------------------------------------------
local windowDragging  = false
local dragStartInput  = Vector2.zero
local frameStartPos   = Vector2.zero
local activeDragInput = nil

local function inputPos(input)
	return Vector2.new(input.Position.X, input.Position.Y)
end

DragBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
		windowDragging  = true
		activeDragInput = input
		dragStartInput  = inputPos(input)
		frameStartPos   = Vector2.new(MainFrame.AbsolutePosition.X, MainFrame.AbsolutePosition.Y)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if not windowDragging then return end
	if input ~= activeDragInput and input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
	local delta  = inputPos(input) - dragStartInput
	local vpSize = workspace.CurrentCamera.ViewportSize
	local newX   = math.clamp(frameStartPos.X + delta.X, 0, vpSize.X - W)
	local newY   = math.clamp(frameStartPos.Y + delta.Y, 0, vpSize.Y - H)
	MainFrame.Position = UDim2.fromOffset(newX, newY)
end)

UserInputService.InputEnded:Connect(function(input)
	if input == activeDragInput or input.UserInputType == Enum.UserInputType.MouseButton1 then
		windowDragging  = false
		activeDragInput = nil
	end
end)

