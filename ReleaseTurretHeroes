------------------------------------------------------------------------
-- TOGGLE
------------------------------------------------------------------------
local toggleStates = {}

local function makeToggle(parent, labelText, default)
	local row = Instance.new("Frame", parent)
	row.Size = UDim2.new(1, 0, 0, 32)
	row.BackgroundColor3 = Color3.fromRGB(26, 26, 32)
	row.BorderSizePixel = 0
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

	local lbl = Instance.new("TextLabel", row)
	lbl.Size = UDim2.new(1, -52, 1, 0)
	lbl.Position = UDim2.new(0, 10, 0, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = labelText
	lbl.TextColor3 = Color3.fromRGB(200, 200, 210)
	lbl.TextSize = 11
	lbl.Font = Enum.Font.Gotham
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	local state = (default == true)

	local track = Instance.new("Frame", row)
	track.Size = UDim2.new(0, 30, 0, 16)
	track.Position = UDim2.new(1, -38, 0.5, -8)
	track.BackgroundColor3 = state and Color3.fromRGB(29, 158, 117) or Color3.fromRGB(55, 55, 70)
	track.BorderSizePixel = 0
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", track)
	knob.Size = UDim2.new(0, 11, 0, 11)
	knob.Position = state and UDim2.new(0, 16, 0.5, -5.5) or UDim2.new(0, 3, 0.5, -5.5)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	toggleStates[labelText] = state

	local btn = Instance.new("TextButton", row)
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.BackgroundTransparency = 1
	btn.Text = ""

	btn.Activated:Connect(function()
		state = not state
		toggleStates[labelText] = state
		TweenService:Create(track, TweenInfo.new(0.2), {
			BackgroundColor3 = state and Color3.fromRGB(29, 158, 117) or Color3.fromRGB(55, 55, 70)
		}):Play()
		TweenService:Create(knob, TweenInfo.new(0.2), {
			Position = state and UDim2.new(0, 16, 0.5, -5.5) or UDim2.new(0, 3, 0.5, -5.5)
		}):Play()
	end)

	return row
end

------------------------------------------------------------------------
-- DROPDOWN
------------------------------------------------------------------------
local function makeDropdown(title, items)
	local HEADER_H = 32
	local ITEM_H   = 32
	local GAP      = 4

	-- Outer container clipped so items hide when collapsed
	local container = Instance.new("Frame", Body)
	container.Size = UDim2.new(1, 0, 0, HEADER_H)
	container.BackgroundTransparency = 1
	container.BorderSizePixel = 0
	container.ClipsDescendants = true

	local containerLayout = Instance.new("UIListLayout", container)
	containerLayout.Padding = UDim.new(0, GAP)
	containerLayout.SortOrder = Enum.SortOrder.LayoutOrder

	-- Header
	local header = Instance.new("Frame", container)
	header.Size = UDim2.new(1, 0, 0, HEADER_H)
	header.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	header.BorderSizePixel = 0
	header.LayoutOrder = 0
	Instance.new("UICorner", header).CornerRadius = UDim.new(0, 7)

	local headerLbl = Instance.new("TextLabel", header)
	headerLbl.Size = UDim2.new(1, -36, 1, 0)
	headerLbl.Position = UDim2.new(0, 10, 0, 0)
	headerLbl.BackgroundTransparency = 1
	headerLbl.Text = title
	headerLbl.TextColor3 = Color3.fromRGB(220, 220, 225)
	headerLbl.TextSize = 11
	headerLbl.Font = Enum.Font.GothamMedium
	headerLbl.TextXAlignment = Enum.TextXAlignment.Left

	local arrow = Instance.new("TextLabel", header)
	arrow.Size = UDim2.new(0, 24, 1, 0)
	arrow.Position = UDim2.new(1, -26, 0, 0)
	arrow.BackgroundTransparency = 1
	arrow.Text = "+"
	arrow.TextColor3 = Color3.fromRGB(120, 120, 140)
	arrow.TextSize = 16
	arrow.Font = Enum.Font.GothamMedium

	local headerBtn = Instance.new("TextButton", header)
	headerBtn.Size = UDim2.new(1, 0, 1, 0)
	headerBtn.BackgroundTransparency = 1
	headerBtn.Text = ""
	headerBtn.ZIndex = 2

	-- Inner list (hidden by default)
	local innerList = Instance.new("Frame", container)
	innerList.Size = UDim2.new(1, 0, 0, 0)
	innerList.AutomaticSize = Enum.AutomaticSize.Y
	innerList.BackgroundTransparency = 1
	innerList.BorderSizePixel = 0
	innerList.LayoutOrder = 1
	innerList.Visible = false

	local innerLayout = Instance.new("UIListLayout", innerList)
	innerLayout.Padding = UDim.new(0, GAP)
	innerLayout.SortOrder = Enum.SortOrder.LayoutOrder

	local innerPad = Instance.new("UIPadding", innerList)
	innerPad.PaddingLeft = UDim.new(0, 8)

	for i, itemName in ipairs(items) do
		local row = makeToggle(innerList, itemName, false)
		row.LayoutOrder = i
	end

	-- Expand / collapse
	local expanded = false
	local expandedH = HEADER_H + GAP + (#items * ITEM_H) + ((#items - 1) * GAP)

	headerBtn.Activated:Connect(function()
		expanded = not expanded
		arrow.Text = expanded and "-" or "+"
		innerList.Visible = expanded
		TweenService:Create(container, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
			Size = UDim2.new(1, 0, 0, expanded and expandedH or HEADER_H)
		}):Play()
	end)

	return container
end

